# NVIDIA API (get key from https://build.nvidia.com)
NVIDIA_API_KEY=
NVIDIA_MODEL=nvidia/nemotron-3-ultra-550b-a55b

# LinkedIn OAuth App credentials (from https://www.linkedin.com/developers)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# LinkedIn refresh token — run: node scripts/get-token.js
LINKEDIN_REFRESH_TOKEN=

# LinkedIn Page ID (optional — if set, posts go to this page instead of your profile)
# Get it from your LinkedIn Page URL: https://www.linkedin.com/company/YOUR-PAGE-ID
LINKEDIN_PAGE_ID=

# Hugging Face token (free — for high-quality FLUX image generation)
# Get from: https://huggingface.co/settings/tokens
HF_API_TOKEN=

# SMTP (for future email feature)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
