# NVIDIA API (get key from https://build.nvidia.com)
NVIDIA_API_KEY=
NVIDIA_MODEL=nvidia/nemotron-3-ultra-550b-a55b

# LinkedIn OAuth App credentials (from https://www.linkedin.com/developers)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# LinkedIn refresh token — run: node scripts/get-token.js
LINKEDIN_REFRESH_TOKEN=

# LinkedIn Page ID (optional — if set, posts go to this page instead of your profile)
# Get it from your LinkedIn Page URL: https://www.linkedin.com/company/YOUR-PAGE-ID
LINKEDIN_PAGE_ID=

# Hugging Face token (free — for high-quality FLUX image generation)
# Get from: https://huggingface.co/settings/tokens
HF_API_TOKEN=

# Zapier MCP token (for posting to LinkedIn + Canva)
# Get from https://mcp.zapier.com
ZAPIER_TOKEN=

# Canva template ID for LinkedIn post designs
# Create a template in Canva, then find its ID in the URL
CANVA_TEMPLATE_ID=

# Figma personal access token (for design assets)
# Get from https://www.figma.com/developers/api#access-tokens
FIGMA_TOKEN=

# Figma file key — from your Figma file URL: figma.com/file/THIS_PART/...
# Only needed if you want Figma designs exported as images
FIGMA_FILE_KEY=

# Figma frame/node ID — the specific frame to export as PNG
# Find by right-clicking a frame in Figma → Copy/Paste as → Copy link
FIGMA_FRAME_ID=
